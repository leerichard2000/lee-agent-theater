# ==============================================================================
# Lee Agent Theater - Variaveis de Ambiente
# ==============================================================================
# Copie este arquivo para .env e ajuste conforme necessario.
# Os valores padrao funcionam para desenvolvimento local.

# --- Server ---
SERVER_PORT=3001
SERVER_HOST=localhost

# --- WebSocket ---
WS_PATH=/ws

# --- Frontend ---
VITE_WS_URL=ws://localhost:3001/ws
VITE_API_URL=http://localhost:3001/api

# --- Sessao ---
MAX_EVENTS_PER_SESSION=1000

# --- Adapter Demo ---
# Intervalo entre eventos simulados em milissegundos
DEMO_EVENT_INTERVAL=2000
# Numero de agentes simulados no modo demo
DEMO_AGENT_COUNT=4

# --- Logging ---
# Niveis disponiveis: debug, info, warn, error
LOG_LEVEL=info
